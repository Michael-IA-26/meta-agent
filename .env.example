# ── Anthropic / LLM ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Microsoft Graph (Outlook — app-only OAuth2) ─────────────────────────────
# Requires Azure App Registration with Mail.Read + Mail.Send (Application, admin-consented)
# Scope the app to compta@jmpartners.fr via Exchange Application Access Policy
GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_SECRET=your-client-secret-here
GRAPH_MAILBOX=compta@jmpartners.fr

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Lovable frontend.
# Leave empty to deny all cross-origin requests (production default).
CORS_ALLOWED_ORIGINS=https://ai-books-buddy.lovable.app,https://preview.lovable.app

# ── Cabinet ─────────────────────────────────────────────────────────────────
CABINET_ID=jmpartners

# ── Scheduler ───────────────────────────────────────────────────────────────
# Set to "true" to enable APScheduler background jobs in main.py.
# Mail polling only starts when GRAPH_TENANT_ID is set.
SCHEDULER_ENABLED=true

# ── Telegram notifications (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Observability (optional) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── Lead Commercial (optional — apps/leadcommercial only) ───────────────────
INSEE_SIRENE_KEY=
INSEE_SIRENE_SECRET=
PAPPERS_API_KEY=
DROPCONTACT_API_KEY=

# ── Legacy (not used by jmpartners — kept for other apps) ───────────────────
OPENAI_API_KEY=sk-proj-...
