# --- Proxy (Fixie) ---
FIXIE_URL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Microsoft Graph (Outlook compta@) --- PRIORITAIRE sur SMTP/IMAP ---
# Créer une App Registration Azure AD, permissions Application : Mail.ReadWrite + Mail.Send
# Consentement admin requis + restriction boîte via New-ApplicationAccessPolicy
# Mettre ces 4 vars dans Doppler prod (env: production)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=compta@jmpartners.fr

# --- SMTP (envoi emails) — fallback si Graph indisponible ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- IMAP (lecture emails entrants jmpartners) — fallback si Graph indisponible ---
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# --- Rapports ---
RAPPORT_DESTINATAIRE=
RAPPORT_EMAIL=

# --- Observabilité ---
SENTRY_DSN=

# --- Gmail OAuth (prod headless) ---
# Générer avec : base64 -i apps/email_agent/token.json | tr -d '\n'
GMAIL_TOKEN_B64=

# --- Divers ---
SCHEDULER_ENABLED=true
LEAD_SCORE_THRESHOLD=50
DOPPLER_ENVIRONMENT=production
